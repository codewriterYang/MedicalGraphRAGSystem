# ===========================================================================
# MedicalGraphRAGSystem 环境配置
# 复制本文件为 .env 并修改：cp .env.example .env  (Windows: copy .env.example .env)
# ===========================================================================

# --- Docker 模式（默认） ---
# WEB_PORT=8000
# 生产环境限制 CORS 来源（逗号分隔）
# ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# --- Neo4j（Docker 模式无需修改，服务名自动为 neo4j） ---
# 本地开发时改为 bolt://127.0.0.1:7687
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme123

# --- LLM 提供商 ---
# 可选: ollama | openai | anthropic
# SiliconFlow 硅基流动（OpenAI 兼容，推荐国内部署）---
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-siliconflow-key-here
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL=deepseek-ai/DeepSeek-V4-Pro
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=1024

# --- Ollama 本地（需自行安装 Ollama 并拉取模型）---
# LLM_PROVIDER=ollama
# LLM_MODEL=qwen3:8b
# LLM_BASE_URL=http://localhost:11434

# --- OpenAI 官方 API ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-api-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# --- Anthropic ---
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# LLM_MODEL=claude-sonnet-4-20250514

# --- 实体匹配 ---
# FUZZY_MATCH_THRESHOLD=80

# --- Spider 备用 LLM（爬虫并发症切分，建议使用不同厂商的 OpenAI 兼容接口）---
# 未配置时自动回退到主 LLM
# SPIDER_LLM_MODEL=deepseek-v4-pro
# SPIDER_LLM_BASE_URL=https://api.ccagent.cn/v1
# SPIDER_LLM_API_KEY=sk-your-spider-key-here

# --- LangSmith 追踪（可选，用于工作流调试与可观测性）---
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls-your-langsmith-api-key-here
# LANGCHAIN_PROJECT=MedicalGraphQA
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
