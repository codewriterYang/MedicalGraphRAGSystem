# ===========================================================================
# EditorConfig — 跨编辑器统一代码风格
# 支持: VS Code, IntelliJ IDEA, Sublime, Vim 等
# 插件: https://editorconfig.org/
# ===========================================================================

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Python
[*.py]
indent_size = 4

# Web 前端
[*.{js,jsx,ts,tsx,css,scss,json,html}]
indent_size = 2

# YAML
[*.{yml,yaml}]
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false

# Shell
[*.{sh,bash}]
indent_size = 2

# Makefile
[Makefile]
indent_style = tab
indent_size = 4
